// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Target {
  id             String          @id @default(uuid())
  email          String         
  name           String?
  phone          String?
  role           String?
  exposureEvents ExposureEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Template {
  id            String     @id @default(uuid())
  name          String
  difficulty    Int        // 1=Obvious, 2=Intermediate, 3=Perfect Clone
  htmlContent   String?
  messageBody   String?

  Campaigns     Campaign[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Campaign {
  id             String          @id @default(uuid())
  name           String
  status         String          @default("DRAFT") // "DRAFT" | "ACTIVE" | "COMPLETED"
  type           String          @default("EMAIL_PHISHING") // "EMAIL_PHISHING" | "SMISHING" | "VISHING" | "WHALING"
  socEmail       String?
  templateId     String
  template       Template        @relation(fields: [templateId], references: [id])
  targetEmails        String          // JSON array string of emails/phones to send to
  simulateBotTraffic  Boolean         @default(false)

  exposureEvents ExposureEvent[]
  analyticReport AnalyticReport?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ExposureEvent {
  id          String   @id @default(uuid())
  targetId    String
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status      String   @default("EXPOSED")
  ipAddress   String?  // Optional, just to see where it came from
  userAgent   String?  // Optional, just for analytics
  createdAt   DateTime @default(now())
}

model AnalyticReport {
  id             String   @id @default(uuid())
  campaignId     String   @unique
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalTargets   Int      @default(0)
  deliveredCount Int      @default(0)
  exposedCount   Int      @default(0)
  generatedAt    DateTime @default(now())
}
